# Reverie API — copy to .env and fill in. NEVER commit the real .env.

# Aurora PostgreSQL (pgvector). Use SQLite locally if unset.
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/DBNAME

# AWS Bedrock (vision captioning + Titan embeddings)
AWS_REGION=ap-south-1
BEDROCK_EMBED_MODEL=amazon.titan-embed-text-v2:0
BEDROCK_VISION_MODEL=apac.anthropic.claude-3-5-sonnet-20241022-v2:0
EMBED_DIM=1024

# CORS + media
CORS_ORIGINS=*
MEDIA_BASE_URL=http://localhost:8000

# ElevenLabs human-voice narration (Polly is the fallback if unset)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=pqHfZKP75CvOlQylNhV4
ELEVENLABS_MODEL=eleven_multilingual_v2
